# Скопируй этот файл в .env и заполни значения ТАМ (в .env, не в .env.example).
PORT=3000
JWT_SECRET=zamenи-na-dlinnuyu-sluchaynuyu-stroku-1234567890

# --- Вход через Telegram ---
# Токен бота из @BotFather (вид: 123456789:AA...). Без него вход через Telegram выключен.
TELEGRAM_BOT_TOKEN=

# Твой личный Telegram ID (владельца) — тебе будут приходить заявки на оплату с кнопками
# Активировать/Отказ. Узнать свой ID: напиши боту команду /id (он ответит числом).
ADMIN_TELEGRAM_ID=

# Адрес приложения — для ссылки входа, которую бот присылает после Start.
APP_URL=https://useboost.ru

# --- ИИ: основной провайдер — Grok (xAI, платный) ---
XAI_API_KEY=
XAI_MODEL=grok-4.5

# --- ИИ: резерв — Groq (бесплатный) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
